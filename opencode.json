{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/minimaxai/minimax-m2.7",
  "mode": {
    "plan": {
      "permissions": {
        "read": true,
        "write": false
      }
    },
    "build": {
      "permissions": {
        "read": true,
        "write": true,
        "bash": true
      }
    }
  },
  "sdd": {
    "specsDir": ".openspec/specs",
    "changesDir": ".openspec/changes",
    "requireSpecBeforeCode": true
  }
}
