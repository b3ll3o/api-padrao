{
  "$schema": "https://opencode.ai/config.json",
  "model": "nvidia/minimaxai/minimax-m2.7",
  "plugin": ["oh-my-opencode-lite", "opencode-plugin-openspec"],
  "mode": {
    "plan": {
      "permissions": {
        "read": true,
        "write": false,
        "bash": false
      }
    },
    "build": {
      "permissions": {
        "read": true,
        "write": true,
        "bash": true
      }
    }
  },
  "skills": {
    "enabled": true,
    "directory": "~/.config/opencode/skills"
  }
}
