# Configurações de Teste E2E

NODE_ENV=test
PORT=3002

# Configurações do Banco de Dados (Porta 5434 mapeada no docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=api-padrao-local

# String de Conexão do Banco de Dados para Testes
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5434/${POSTGRES_DB}?schema=public"

# Configurações do OpenTelemetry (desativado ou local para testes)
OTEL_SERVICE_NAME=api-padrao-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# JWT Secret para Testes (mínimo 32 caracteres exigido pela env validation)
JWT_SECRET=testSecretKeyForE2EOnlyPaddingForMinLength32
JWT_ACCESS_EXPIRES_IN=300s
JWT_REFRESH_EXPIRES_DAYS=7

# URL base do frontend (usado para montar o link de reset)
FRONTEND_URL=http://localhost:3000

# TTL do token de reset em minutos
PASSWORD_RESET_EXPIRES_MINUTES=60

# Throttler: limites muito altos para evitar 429 entre testes E2E
# (o throttler continua configurado em produção, apenas com folga aqui)
THROTTLER_SHORT_TTL=1000
THROTTLER_SHORT_LIMIT=10000
THROTTLER_MEDIUM_TTL=10000
THROTTLER_MEDIUM_LIMIT=10000
THROTTLER_LONG_TTL=60000
THROTTLER_LONG_LIMIT=10000
THROTTLER_SENSITIVE_TTL=60000
THROTTLER_SENSITIVE_LIMIT=10000
# O decorator @Throttle em auth.controller.ts lê o limit em tempo de
# carregamento do módulo, por isso o .env.test precisa estar disponível
# antes do decorator ser avaliado. setup-e2e.ts carrega este arquivo.
THROTTLER_SENSITIVE_LIMIT_FORGOT=10000
THROTTLER_SENSITIVE_LIMIT_RESET=10000
THROTTLER_SENSITIVE_LIMIT_REFRESH=10000
