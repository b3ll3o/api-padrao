# Exemplo de configuração para Testes E2E
# Copie este arquivo para `.env.test` (que está no .gitignore) antes de rodar
# `npm run test:migrate` e `npm run test:e2e`.

NODE_ENV=test
PORT=3002

# Banco de Dados (Postgres exposto em 5434 no host conforme docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=api-padrao-local

# String de Conexão para Testes
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5434/${POSTGRES_DB}?schema=public"

# OpenTelemetry (desativado em testes; collector local opcional)
OTEL_SERVICE_NAME=api-padrao-test
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# JWT
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=300s
JWT_REFRESH_EXPIRES_DAYS=7

# Throttler: limites altos para não interferir com testes E2E
THROTTLER_SHORT_TTL=1000
THROTTLER_SHORT_LIMIT=10000
THROTTLER_MEDIUM_TTL=10000
THROTTLER_MEDIUM_LIMIT=10000
THROTTLER_LONG_TTL=60000
THROTTLER_LONG_LIMIT=10000
THROTTLER_SENSITIVE_TTL=60000
THROTTLER_SENSITIVE_LIMIT=10000
THROTTLER_SENSITIVE_LIMIT_FORGOT=10000
THROTTLER_SENSITIVE_LIMIT_RESET=10000
THROTTLER_SENSITIVE_LIMIT_REFRESH=10000

# URL base do frontend (usado para montar o link de reset)
FRONTEND_URL=http://localhost:3000

# TTL do token de reset em minutos
PASSWORD_RESET_EXPIRES_MINUTES=60

# [email-notifications] E-mails transacionais habilitados em testes
EMAIL_NOTIFICATIONS_ENABLED=true
APP_NAME=API Padrão
APP_LOGIN_URL=http://localhost:3000
EMAIL_NOTIFICATIONS_METRICS_ENABLED=false

# [SEC-003] Trust proxy desligado em testes (sem LB/reverse proxy)
TRUST_PROXY=false
# [SEC-004] CORS permissivo em testes
ALLOWED_ORIGINS=*
