// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditLog {
  id        String   @id @default(uuid())
  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  acao      String
  recurso   String
  recursoId String?
  detalhes  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([recurso, recursoId])
}

model Usuario {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  senha               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  ativo               Boolean              @default(true)
  empresas            UsuarioEmpresa[]
  empresasResponsavel Empresa[]            @relation("EmpresaResponsavel")
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  loginHistory        LoginHistory[]
  passwordResetTokens PasswordResetToken[]

  @@index([deletedAt, ativo])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    Int
  user      Usuario   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    Int
  user      Usuario  @relation(fields: [userId], references: [id])
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  // [SEC-001] `tokenHash` armazena SHA-256(token) em vez do token bruto.
  // Persistir o token em plaintext é um data breach de uma decisão — um
  // dump da tabela entrega todos os refresh tokens ativos e permite
  // hijack de sessão. O cliente continua recebendo o token bruto no
  // login; o hash é apenas a forma de lookup no DB.
  // Segue o mesmo padrão de `PasswordResetToken.tokenHash`.
  tokenHash String    @unique
  userId    Int
  user      Usuario   @relation(fields: [userId], references: [id])
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// [H3] Fallback Prisma para `LoginAttemptTracker` (account lockout).
//
// A porta de domínio consulta Redis primeiro (rápido, com TTL nativo).
// Quando o Redis está offline (`cache.get`/`set` lançam), o adapter cai
// para esta tabela — escrita síncrona, sem fail-open. Cada linha registra
// uma tentativa de login (falha OU sucesso) com timestamp preciso, e o
// lockout é derivado contando `success = false` dentro da janela.
//
// Os índices cobrem os dois caminhos de query:
// - `email + attemptedAt`: lockout por conta (mesmo email).
// - `ip + attemptedAt`: defesa adicional por IP (futuro, brute-force
//   distribuído entre vários emails).
//
// NÃO usar como auditoria primária — `AuditLog` continua sendo o log
// canônico de eventos sensíveis; esta tabela é estado para o lockout.
model LoginAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @db.VarChar(255)
  ip            String?  @db.VarChar(45)
  userAgent     String?  @db.VarChar(500)
  success       Boolean  @default(false)
  failureReason String?  @db.VarChar(50)
  attemptedAt   DateTime @default(now()) @db.Timestamptz

  @@index([email, attemptedAt])
  @@index([ip, attemptedAt])
  @@map("login_attempts")
}

model Perfil {
  id              Int              @id @default(autoincrement())
  nome            String
  codigo          String
  descricao       String
  createdAt       DateTime?        @default(now())
  updatedAt       DateTime?        @updatedAt
  usuariosEmpresa UsuarioEmpresa[]
  permissoes      Permissao[]
  deletedAt       DateTime?
  ativo           Boolean          @default(true)
  empresa         Empresa          @relation(fields: [empresaId], references: [id])
  empresaId       String

  @@unique([nome, empresaId])
  @@unique([codigo, empresaId])
  @@index([empresaId, deletedAt, ativo])
}

model Permissao {
  id        Int       @id @default(autoincrement())
  nome      String    @unique
  codigo    String    @unique
  descricao String
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  perfis    Perfil[]
  deletedAt DateTime?
  ativo     Boolean   @default(true)

  @@index([deletedAt, ativo])
}

model Empresa {
  id            String           @id @default(uuid())
  nome          String
  descricao     String?
  ativo         Boolean          @default(true)
  responsavel   Usuario          @relation("EmpresaResponsavel", fields: [responsavelId], references: [id])
  responsavelId Int
  usuarios      UsuarioEmpresa[]
  perfis        Perfil[]
  plano         Plano            @default(FREE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([responsavelId])
  @@index([deletedAt, ativo])
  @@index([plano])
  // [PERF-003] Índice composto para a query mais comum:
  // "listar empresas ativas por plano, excluindo soft-deleted".
  // Suporta `WHERE plano = $1 AND deletedAt IS NULL AND ativo = true`
  // sem varredura sequencial.
  @@index([plano, deletedAt, ativo])
}

enum Plano {
  FREE
  PRO
  ENTERPRISE
}

model UsuarioEmpresa {
  id        Int      @id @default(autoincrement())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String
  perfis    Perfil[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, empresaId])
}
